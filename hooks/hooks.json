{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-prefs-init.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start-handoff.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/brevity-reinforce.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start-token-check.sh" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/brevity-drift.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/dispatch-nudge.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/bulk-job-reminder.sh" }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/subagent-log.sh" }
        ]
      },
      {
        "matcher": "Workflow",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/workflow-roster-check.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-tsc.sh" }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/subagent-complete-log.sh" }
        ]
      }
    ]
  }
}
