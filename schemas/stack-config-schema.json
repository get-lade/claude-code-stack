{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/bschonbrun/claude-code-stack/schemas/stack-config-schema.json",
  "title": "Stack Project Configuration",
  "description": "Per-project configuration for Claude Code Stack. Lives at <project>/.claude/stack-config.json. Created by /project-init, edited by /default-edit project and shortcut skills.",
  "type": "object",
  "required": ["stack_version", "stack_tier", "purpose", "created"],
  "properties": {
    "stack_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the stack this config was created against."
    },
    "stack_tier": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5,
      "description": "Active stack tier (0=Foundation through 5=Local+Offline)."
    },
    "purpose": {
      "type": "string",
      "description": "One-line description of what this project is for."
    },
    "created": { "type": "string", "format": "date" },
    "last_modified": { "type": "string", "format": "date" },
    "orchestration_mode": {
      "type": "string",
      "enum": ["main-thread", "agent-teams", "hybrid"],
      "default": "main-thread",
      "description": "v1.1: How foreman dispatches subagents. main-thread is trusted default; agent-teams uses Anthropic's experimental feature; hybrid mixes."
    },
    "strict_mode": {
      "type": "boolean",
      "default": true,
      "description": "If true, foreman refuses to dispatch in projects without stack-config.json."
    },
    "domain_mode": {
      "type": ["string", "null"],
      "enum": ["financial-code", "schema-migration", "deploy", "ui-design", "data-operation", null],
      "description": "Activates extra safety rules in foreman. null means no special mode."
    },
    "sensitivity": {
      "type": "object",
      "properties": {
        "level": {
          "type": "string",
          "enum": ["normal", "sensitive", "confidential"],
          "default": "normal"
        },
        "notes": { "type": "string" }
      },
      "required": ["level"]
    },
    "active_subagents": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Subagents enabled for this project. Empty array means use tier defaults."
    },
    "required_approvals": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["pre-merge", "pre-deploy", "pre-schema-change", "pre-bulk-job"]
      }
    },
    "model_overrides": {
      "type": "object",
      "description": "Per-subagent model overrides. Keys are subagent names; values are model identifiers from model-routing.json.",
      "additionalProperties": { "type": "string" }
    },
    "skill_overrides": {
      "type": "object",
      "description": "Per-skill behavioral overrides.",
      "additionalProperties": true
    },
    "cost_protection": {
      "type": "object",
      "properties": {
        "per_session_alert_usd": { "type": ["number", "null"], "minimum": 0 },
        "per_day_alert_usd": { "type": ["number", "null"], "minimum": 0 },
        "per_session_hard_cap_usd": { "type": ["number", "null"], "minimum": 0 }
      }
    },
    "change_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "setting", "old_value", "new_value", "reason", "scope", "invoked_via"],
        "properties": {
          "date": { "type": "string", "format": "date-time" },
          "setting": { "type": "string", "description": "Dot-path of changed setting" },
          "old_value": {},
          "new_value": {},
          "reason": { "type": "string" },
          "scope": { "type": "string", "enum": ["project", "global"] },
          "also_updated_global": { "type": "boolean" },
          "invoked_via": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": false
}
