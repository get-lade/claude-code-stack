{
  "$schema": "https://github.com/bschonbrun/claude-code-stack/schemas/stack-config-schema.json",
  "stack_version": "1.1.4",
  "stack_tier": 2,
  "purpose": "<one-line description>",
  "created": "YYYY-MM-DD",
  "last_modified": "YYYY-MM-DD",
  "orchestration_mode": "main-thread",
  "strict_mode": true,
  "domain_mode": null,
  "sensitivity": {
    "level": "normal",
    "notes": ""
  },
  "active_subagents": [],
  "required_approvals": [],
  "model_overrides": {},
  "skill_overrides": {},
  "cost_protection": {
    "per_session_alert_usd": 5.00,
    "per_day_alert_usd": 50.00,
    "per_session_hard_cap_usd": null
  },
  "brevity": {
    "enabled": true,
    "word_budget": 120,
    "sentence_budget": 6
  },
  "session_prefs": {
    "communication_style": "balanced",
    "model_effort": "balanced",
    "explanation_verbosity": "normal",
    "cost_alert_sensitivity": "normal"
  },
  "loop_policy": {
    "enabled": true,
    "default_autonomy": "checkpoint",
    "autonomy_ceiling": "checkpoint",
    "max_iterations": 25,
    "max_recursion_depth": 5,
    "per_run_budget_usd": 5,
    "timeout_minutes": 180,
    "no_progress_exit": true,
    "require_external_termination": "auto",
    "commit_per_iteration": false,
    "irreversible_actions_break_loop": true
  },
  "change_history": []
}
