{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/loop-stop.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/dispatch-nudge.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/bulk-job-reminder.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/irreversible-deny.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/schema-deploy-gate.sh"
          }
        ]
      },
      {
        "matcher": "mcp__.*__(apply_migration|execute_sql|deploy_edge_function)",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/schema-deploy-gate.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/subagent-log.sh"
          }
        ]
      },
      {
        "matcher": "Workflow",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/workflow-roster-check.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/subagent-complete-log.sh"
          }
        ]
      }
    ]
  }
}
