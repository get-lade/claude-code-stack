  "requirements": [
    { "type": "command", "name": "jq" },
    { "type": "command", "name": "codex" },
    { "type": "supabase_project", "name": "<your-supabase-ref>" }
  ],
  "smoke_tests": [
    "test -f ~/.claude/agents/architect.md",
    "test -f ~/.claude/agents/implementer.md",
    "test -f ~/.claude/agents/validator.md",
    "test -f ~/.claude/agents/reviewer.md",
    "test -f ~/.claude/agents/tester.md",
    "test -f ~/.claude/agents/documenter.md",
    "test -f ~/.claude/agents/scribe.md",
    "test -f ~/.claude/agents/ops.md",
    "test -f ~/.claude/agents/product-critic.md",
    "test -f ~/.claude/agents/designer.md",
    "test -f ~/.claude/agents/red-team.md",
    "test -f ~/.claude/agents/security-auditor.md",
    "test -f ~/.claude/agents/foreman-team-lead.md",
    "test -f ~/.claude/skills/foreman/SKILL.md",
    "test -f ~/.claude/skills/dispatch/SKILL.md",
    "test -f ~/.claude/skills/adr/SKILL.md",
    "test -f ~/.claude/skills/runbook/SKILL.md",
    "test -f ~/.claude/skills/design-match/SKILL.md",
    "test -f ~/.claude/skills/eval-bump/SKILL.md",
    "test -f ~/.claude/skills/deploy-edge/SKILL.md",
    "test -f ~/.claude/skills/recommend-capabilities/SKILL.md",
    "test -f ~/.claude/skills/suggest/SKILL.md",
    "test -f ~/.claude/skills/config/SKILL.md",
    "test -f ~/.claude/skills/stack-config/SKILL.md",
    "test -f ~/.claude/skills/native-settings-edit/SKILL.md",
    "test -x ~/.claude/skills/native-settings-edit/native_settings_edit.py",
    "test -f ~/.claude/config/capability-registry.json",
    "test -f ~/.claude/config/model-routing.json",
    "test -f ~/.claude/config/approval-gates.json",
    "test -f ~/.claude/config/prompt-caching.json",
    "test -x ~/.claude/hooks/subagent-log.sh",
    "test -x ~/.claude/hooks/subagent-complete-log.sh",
    "test -x ~/.claude/hooks/dispatch-nudge.sh",
    "command -v codex",
    "test -x ~/.claude/hooks/workflow-roster-check.sh",
    "jq -e '[.hooks.PreToolUse[]? | select(.matcher==\"Agent\")] | length >= 1' ~/.claude/settings.json",
    "jq -e '[.hooks.PreToolUse[]? | select(.matcher==\"Workflow\")] | length >= 1' ~/.claude/settings.json",
    "jq -e '[.hooks.PostToolUse[]? | select(.matcher==\"Agent\")] | length >= 1' ~/.claude/settings.json",
    "jq -e '[.hooks.UserPromptSubmit[]?.hooks[]? | select(.command | test(\"dispatch-nudge\"))] | length >= 1' ~/.claude/settings.json",
    "test -f ~/.claude/skills/loop-engineer/SKILL.md && test -x ~/.claude/hooks/loop-stop.sh",
    "test -f ~/.claude/skills/loop-engineer/loop_lib.sh",
    "test -x ~/.claude/hooks/irreversible-deny.sh",
    "jq -e '[.hooks.Stop[]?.hooks[]? | select(.command | test(\"loop-stop.sh\"))] | length >= 1' ~/.claude/settings.json",
    "jq -e '[.hooks.PreToolUse[]? | select(.matcher==\"Bash\") | .hooks[]? | select(.command | test(\"irreversible-deny.sh\"))] | length >= 1' ~/.claude/settings.json",
    "test -x ~/.claude/hooks/schema-deploy-gate.sh",
    "jq -e '[.hooks.PreToolUse[]? | select(.matcher==\"Bash\") | .hooks[]? | select(.command | test(\"schema-deploy-gate.sh\"))] | length >= 1' ~/.claude/settings.json",
    "jq -e '[.hooks.PreToolUse[]? | select(.matcher | test(\"apply_migration\")) | .hooks[]? | select(.command | test(\"schema-deploy-gate.sh\"))] | length >= 1' ~/.claude/settings.json",
    "test -x ~/.claude/hooks/override-log.sh",
    "jq -e '[.hooks.PreToolUse[]? | select(.matcher==\"Agent\") | .hooks[]? | select(.command | test(\"override-log.sh\"))] | length >= 1' ~/.claude/settings.json",
    "test -x ~/.claude/scripts/lib/cross-family-preflight.sh"
  ],
  "manifest_format_note": "Tier-2 manifest uses the same files.global / from-to / smoke_tests format as tier 0, 1, 3, 4, 5 and the install.sh / verify.sh scripts. Artifact 3's draft used a divergent installs.* / src-dest / verify structure that the installer does not read — corrected here for consistency. See Tier 2 install log.",
  "codex_note": "Artifact 3's tier-2 manifest required Keychain item `openai-api-key`. Per the maintainer's decision (2026-05-16, ADR-011), OpenAI-family work routes through the local Codex CLI instead — the requirement is now `command: codex`."
