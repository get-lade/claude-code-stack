{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "fileCheckpointingEnabled": true,
  "autoCompactEnabled": true,
  "permissions": {
    "defaultMode": "auto",
    "additionalDirectories": []
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-start-handoff.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/bulk-job-reminder.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/post-tool-tsc.sh"
          }
        ]
      }
    ]
  }
}
