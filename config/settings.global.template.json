{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "fileCheckpointingEnabled": true,
  "autoCompactEnabled": true,
  "remoteControlAtStartup": true,
  "permissions": {
    "defaultMode": "auto",
    "additionalDirectories": []
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/hooks/statusline.sh"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-prefs-init.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/session-start-handoff.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/brevity-reinforce.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/session-start-token-check.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/brevity-drift.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/bulk-job-reminder.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/post-tool-tsc.sh"
          }
        ]
      }
    ]
  }
}
